<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#FFFDFEFF"
                android:endColor="#FFF3F6FA" />
            <corners android:radius="32dp" />
        </shape>
    </item>

    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#1F1A2A3A" />
            <corners android:radius="31dp" />
        </shape>
    </item>

    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="24dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#52FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="30dp" />
        </shape>
    </item>
</layer-list>
